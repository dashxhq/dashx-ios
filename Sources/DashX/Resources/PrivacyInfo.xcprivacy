<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Whether this SDK uses data for tracking (cross-app advertising). DashX is an
	     engagement/analytics SDK and does not link user data with third-party ad networks. -->
	<key>NSPrivacyTracking</key>
	<false/>

	<!-- No tracking domains since NSPrivacyTracking is false. -->
	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<!-- Required-reason APIs accessed by the SDK. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!-- UserDefaults is used to persist anonymous user ID, account UID, and
			     app build version across sessions for SDK state management. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<!-- CA92.1: Read/write information used only to manage the SDK's status;
				     data is not shared or used to derive information about the user. -->
				<string>CA92.1</string>
			</array>
		</dict>
	</array>

	<!-- Data types collected and sent to DashX servers as part of system context. -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array>

		<!-- UIDevice.identifierForVendor – a per-vendor device identifier used to
		     distinguish devices in analytics events. -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeDeviceID</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>

		<!-- ASIdentifierManager.advertisingIdentifier (IDFA) – collected only when the
		     host app calls enableAdTracking() and the user grants ATT permission. -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeAdvertisingData</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<true/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
			</array>
		</dict>

		<!-- IPv4/IPv6 addresses collected via getifaddrs() and sent as part of
		     SystemContextInput to infer approximate network location. -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeIPAddress</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
			</array>
		</dict>

		<!-- App lifecycle events (install, open, background, update, crash) and
		     custom track() events emitted by the host app. -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeOtherUsageData</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>

	</array>
</dict>
</plist>
